          "copy_to": "suggest_title"
        },
        "suggest_title": {
          "type": "completion"
        },
        "marcid": {
          "type": "double"
        },
        "keywords": {
          "type": "keyword"
        },
        "publication_date": {
          "type": "date",
          "format": "date"
        },
        "_created": {
          "type": "date"
        },
        "_updated": {
          "type": "date"
        }
      }
    }
  }
}
